# Stack Auth — 本地开发环境配置
# 由 Terraform 自动生成，请勿手动编辑
# project_id / client_key / secret_key 来自 https://app.stack-auth.com

NEXT_PUBLIC_STACK_PROJECT_ID=${project_id}
NEXT_PUBLIC_STACK_PUBLISHABLE_CLIENT_KEY=${client_key}
STACK_SECRET_SERVER_KEY=${secret_key}
STACK_DATABASE_URL=postgres://${db_user}:${db_password}@127.0.0.1:${db_port}/${db_name}
