# Stack Auth — 本地开发环境配置
# 由 Terraform 自动生成，请勿手动编辑
# 参考来源：https://github.com/hexclave/stack-auth/blob/dev/docker/server/.env.example

NEXT_PUBLIC_STACK_API_URL=http://127.0.0.1:${api_port}
NEXT_PUBLIC_STACK_DASHBOARD_URL=http://127.0.0.1:${dashboard_port}
STACK_DATABASE_CONNECTION_STRING=postgres://${db_user}:${db_password}@127.0.0.1:${db_port}/${db_name}
STACK_SERVER_SECRET=${server_secret}
STACK_SEED_INTERNAL_PROJECT_ALLOW_LOCALHOST=true
STACK_SEED_INTERNAL_PROJECT_SIGN_UP_ENABLED=true
STACK_RUN_MIGRATIONS=true
STACK_RUN_SEED_SCRIPT=true
